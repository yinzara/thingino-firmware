From d7cb78919df1e653037eb2b01454073f6f1be721 Mon Sep 17 00:00:00 2001
From: Matthew Vance <yinzara@gmail.com>
Date: Tue, 11 Nov 2025 10:30:52 -0800
Subject: [PATCH] bluez: Add comprehensive debug logging for ATT and GATT

Add fprintf(stderr) logging to track ATT and GATT operations:

ATT layer (src/shared/att.c):
- Log every outgoing ATT PDU with opcode and length
- Log every incoming ATT PDU with opcode and length
- Add stdio.h include for fprintf

GATT server layer (src/shared/gatt-server.c):
- Log Read By Group Type requests (service discovery)
- Log successful responses with response length
- Log error responses with error code and handle

This helps diagnose why phones disconnect after MTU exchange,
typically due to missing GATT services or permission issues.
---
 src/shared/att.c         | 3 +++
 src/shared/gatt-server.c | 3 +++
 2 files changed, 6 insertions(+)

diff --git a/src/shared/att.c b/src/shared/att.c
index 4a406f4..fd44ea8 100644
--- a/src/shared/att.c
+++ b/src/shared/att.c
@@ -15,6 +15,7 @@
 #include <stdlib.h>
 #include <unistd.h>
 #include <errno.h>
+#include <stdio.h>
 
 #include "src/shared/io.h"
 #include "src/shared/queue.h"
@@ -526,6 +527,7 @@ static ssize_t bt_att_chan_write(struct bt_att_chan *chan, uint8_t opcode,
 	iov.iov_len = len;
 
 	VERBOSE(att, "(chan %p) ATT op 0x%02x", chan, opcode);
+	fprintf(stderr, "ATT_DEBUG: Sending ATT PDU opcode=0x%02x len=%u\n", opcode, len);
 
 	ret = io_send(chan->io, &iov, 1);
 	if (ret < 0) {
@@ -1094,6 +1096,7 @@ static bool can_read_data(struct io *io, void *user_data)
 		 */
 		DBG(att, "(chan %p) ATT PDU received: 0x%02x", chan,
 							opcode);
+		fprintf(stderr, "ATT_DEBUG: Received ATT PDU opcode=0x%02x len=%zd\n", opcode, bytes_read);
 		handle_notify(chan, pdu, bytes_read);
 		break;
 	}
diff --git a/src/shared/gatt-server.c b/src/shared/gatt-server.c
index b30ec8c..eb17242 100644
--- a/src/shared/gatt-server.c
+++ b/src/shared/gatt-server.c
@@ -292,6 +292,7 @@ static void read_by_grp_type_cb(struct bt_att_chan *chan, uint16_t mtu,
 	end = get_le16(pdu + 2);
 	get_uuid_le(pdu + 4, length - 4, &type);
 
+	fprintf(stderr, "GATT_DEBUG: Read By Grp Type - start: 0x%04x end: 0x%04x length: %u\n", start, end, length);
 	DBG(server, "Read By Grp Type - start: 0x%04x end: 0x%04x", start, end);
 
 	if (!start || !end) {
@@ -334,12 +335,14 @@ static void read_by_grp_type_cb(struct bt_att_chan *chan, uint16_t mtu,
 
 	queue_destroy(q, NULL);
 
+	fprintf(stderr, "GATT_DEBUG: Sending READ_BY_GRP_TYPE_RSP, rsp_len=%u\n", rsp_len);
 	bt_att_chan_send_rsp(chan, BT_ATT_OP_READ_BY_GRP_TYPE_RSP,
 						rsp_pdu, rsp_len);
 
 	return;
 
 error:
+	fprintf(stderr, "GATT_DEBUG: Sending ERROR_RSP for READ_BY_GRP_TYPE, ehandle=0x%04x ecode=0x%02x\n", ehandle, ecode);
 	queue_destroy(q, NULL);
 	bt_att_chan_send_error_rsp(chan, opcode, ehandle, ecode);
 }
