#!/bin/sh

DAEMON="wlan_power"

start() {
	# Only run if wlan module is atbm6031x
	wlan_module=$(fw_printenv -n wlan_module 2>/dev/null)
	[ "$wlan_module" = "atbm6031x" ] || exit 0

	printf "Starting %s: " "$DAEMON"

	# GPIO 48 should already be ON from U-Boot gpio_wlan setting,
	# but verify it's powered on just in case
	if [ -d /sys/class/gpio/gpio48 ]; then
		# Already exported, just ensure it's HIGH
		[ "$(cat /sys/class/gpio/gpio48/value 2>/dev/null)" != "1" ] && \
			echo 1 > /sys/class/gpio/gpio48/value 2>/dev/null
	fi

	# Small delay for WiFi chip to stabilize
	sleep 1

	# Rebind mmc1 controller to detect SDIO card (needed because mmc1
	# initializes before GPIO 48 is set by U-Boot, so it doesn't see the card)
	if [ -d /sys/devices/platform/jzmmc_v1.2.1 ]; then
		echo "jzmmc_v1.2.1" > /sys/bus/platform/drivers/jzmmc_v1.2/unbind 2>/dev/null
		sleep 0.5
		echo "jzmmc_v1.2.1" > /sys/bus/platform/drivers/jzmmc_v1.2/bind 2>/dev/null
		sleep 2
	fi

	echo "OK"
}

case "$1" in
	start)
		start
		;;
	stop|restart|reload)
		# Nothing to do
		;;
	*)
		echo "Usage: $0 {start|stop|restart|reload}"
		exit 1
		;;
esac
