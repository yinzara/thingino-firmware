#!/bin/sh

. /usr/share/common

start() {
	echo_info "Initializing ATBM6031X Bluetooth"

	# Check if ATBM module loaded
	if ! lsmod | grep -q "atbm6031x"; then
		echo_warning "ATBM6031X WiFi module not loaded - skipping bluetooth init"
		return 0  # Don't fail boot, just skip
	fi

	# Check if wifi_bt_comb parameter is set
	BT_COMB=$(cat /sys/module/atbm6031x/parameters/wifi_bt_comb 2>/dev/null)
	if [ "$BT_COMB" != "1" ]; then
		echo_warning "wifi_bt_comb=$BT_COMB - BLE not enabled"
		echo_info "Reloading module with BLE support..."

		# Save interface status
		ifdown wlan0 2>/dev/null

		# Reload module with BLE parameter
		rmmod atbm6031x
		sleep 1
		modprobe atbm6031x wifi_bt_comb=1
		sleep 2

		# Restore interface
		ifup wlan0 2>/dev/null &

		# Verify parameter was set
		BT_COMB=$(cat /sys/module/atbm6031x/parameters/wifi_bt_comb 2>/dev/null)
		if [ "$BT_COMB" != "1" ]; then
			echo_error "Failed to enable BLE support"
			return 1
		fi
		echo_info "BLE support enabled successfully"
	fi

	echo_info "BLE enabled via SDIO interface"

	# Wait for HCI device to appear (up to 5 seconds)
	retry=10
	while [ $retry -gt 0 ]; do
		if [ -e /sys/class/bluetooth/hci0 ]; then
			echo_info "HCI device hci0 detected"
			break
		fi
		sleep 0.5
		retry=$((retry - 1))
	done

	if [ ! -e /sys/class/bluetooth/hci0 ]; then
		echo_warning "HCI device hci0 not found - skipping bluetooth init"
		return 0  # Don't fail boot, just skip
	fi

	# Bring up HCI interface
	if command -v hciconfig >/dev/null 2>&1; then
		hciconfig hci0 up && echo_info "HCI interface hci0 brought up" || echo_warning "Failed to bring up hci0"
	else
		echo_warning "hciconfig not available"
	fi

	echo_info "Bluetooth initialization complete"
}

stop() {
	if command -v hciconfig >/dev/null 2>&1 && [ -e /sys/class/bluetooth/hci0 ]; then
		hciconfig hci0 down
		echo_info "HCI interface hci0 shut down"
	fi
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
